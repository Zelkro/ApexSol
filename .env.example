# System Settings
QUEUE_SIZE=10000
QUEUE_OVERFLOW_POLICY=drop_oldest # drop_oldest, drop_newest, fail_closed
MAX_SLOT_LAG=10
STALENESS_THRESHOLD_SECONDS=5.0
